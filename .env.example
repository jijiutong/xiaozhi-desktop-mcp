# Absolute path to your Obsidian vault.
OBSIDIAN_VAULT=/path/to/your/obsidian-vault

# Relative file inside the vault for quick captured memories.
OBSIDIAN_MEMORY_FILE=00-Inbox/voice-memory.md

# Relative or absolute directory for cc/Codex task files.
CC_TASKS_DIR=00-Inbox/cc-tasks

# Optional category/intent registry for the generic desktop_intent entry.
DESKTOP_MCP_CONFIG=desktop-mcp.yaml

# Optional default project path stored in generated cc/Codex tasks.
DEFAULT_PROJECT_ROOT=/path/to/your/project

# Claude Code/Codex managed session settings.
# 默认能玩：slash 命令全部允许；需要收紧时改 confirm/deny。
CC_ALLOWED_PROJECTS=/path/to/your/project,/path/to/another/project
CC_ALLOWED_CLIS=claude,codex
CC_DEFAULT_CLI=claude
CC_ALLOWED_CLI_ARGS=-c,--continue
CC_VISIBLE_TERMINALS=Terminal,iTerm
XCODE_ALLOWED_PROJECTS=/path/to/your/project,/path/to/another/project
# Empty means all model names are allowed. Set a comma list to restrict.
CC_ALLOWED_MODELS=
CC_SLASH_DEFAULT_POLICY=allow
CC_SLASH_ALLOW=
CC_SLASH_CONFIRM=
CC_SLASH_DENY=
CC_LOG_ENABLED=false
CC_STATUS_TAIL_CHARS=4000
CC_MAX_RETURN_CHARS=8000

# Comma-separated allowlist for app.open.
ALLOWED_APPS=Obsidian,Xcode,Google Chrome,Safari,Music,Finder,Terminal,Codex

# HTTP adapter for Java xiaozhi-esp32-server integration.
DESKTOP_MCP_HTTP_HOST=127.0.0.1
DESKTOP_MCP_HTTP_PORT=8765
# Required when DESKTOP_MCP_HTTP_HOST is not localhost/127.0.0.1/::1.
DESKTOP_MCP_AUTH_TOKEN=
